# ==============================================================================
# ARC AGENT ECONOMY - GLOBAL CONFIGURATION
# ==============================================================================

# --- NETWORK CONFIG (ARC TESTNET) ---
ARC_RPC_URL=https://rpc.arc.network
AGENT_REGISTRY_ADDRESS=0x8b8c8c03eee05334412c73b298705711828e9ca1
TASK_ESCROW_ADDRESS=0xecb2a3e501f970e16fb8fd75e1af5cdad11c283c

# --- CIRCLE INFRASTRUCTURE (Required for Swarm Master) ---
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_32_byte_hex_entity_secret_here

# --- NANO-PAYMENT BATCHING (x402) ---
# Official GatewayMinter on ARC Testnet
CIRCLE_GATEWAY_ADDRESS=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B

# --- PERSISTENCE (MongoDB Atlas) ---
# Used for mapping Agent Identities to Circle Wallet IDs
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/arc_economy

# --- SMART CONTRACT DEPLOYMENT ---
# ONLY needed for running 'forge script' or 'npm run deploy'
# DO NOT keep this in production environments
PRIVATE_KEY=your_deployer_private_key_here
