# Environment Configuration for Swarm Master
# Rename this file to .env on the server.
# NEVER commit this file to GitHub after filling in values.

# Circle API Configuration
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here
WALLET_SET_ID=your_wallet_set_id_here

# Blockchain Configuration
ESCROW_CA=0x57082a289C34318ab216920947efd2FFB0b9981b
PORT=3001

# Master API Security (Optional Token Saske will use to authenticate)
MASTER_API_TOKEN=generate_a_random_secure_token_here
